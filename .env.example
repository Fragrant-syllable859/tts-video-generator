# ===========================================
# TTS Video Generator - Configuration
# Copy this file to .env and fill in your values
# ===========================================

# --- Required: ElevenLabs API ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# --- Paths (defaults work if files are in the project directory) ---
# DOCX_PATH=scripts.docx
# AUDIO_DIR=audio_output
# BG_DIR=backgrounds
# BGM_DIR=bgm
# OUTPUT_DIR=video_output
# BASE_DIR=

# --- FFmpeg (defaults to system PATH) ---
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe

# --- Content Settings ---
# START_FROM=1
# BGM_VOLUME=0.12

# --- Text Extraction Tags ---
# Customize these to match your Word document format
# TEXT_TAG=【Text】
# END_TAGS=【Translation】,【Tags】

# --- ElevenLabs Model ---
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# TTS_STABILITY=0.5
# TTS_SIMILARITY_BOOST=0.75

# --- Subtitle Style ---
# SUBTITLE_FONT=Arial
# TITLE_FONTSIZE=60
# SUB_FONTSIZE=48
# SUB_MAX_LINE_CHARS=16
# TITLE_MAX_LINE_CHARS=14

# --- Video Resolution ---
# VIDEO_WIDTH=1080
# VIDEO_HEIGHT=1920

# --- Sentence Splitting ---
# Regex pattern for sentence-ending punctuation
# SENTENCE_SPLIT_PATTERN=(?<=[。！？!?.])
